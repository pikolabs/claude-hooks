#!/usr/bin/env bash
# Piko git pre-commit hook. Enforces pikolabs.ai email identity on commits
# in PikoLabs repositories only, whether the commit is driven by Claude or not.
# Non-pikolabs repositories (personal projects) are left untouched so the
# global core.hooksPath installation does not overreach.
# Bypass (documented, audit-logged): PIKO_HOOK_BYPASS=1 git commit ...

set -euo pipefail

# Scope: enforce only when the current repo's origin points at pikolabs.
remote="$(git config --get remote.origin.url 2>/dev/null || true)"
case "${remote}" in
  *pikolabs/*|*pikolabs.ai*|*github-piko:*)
    ;;
  "")
    # No origin configured (fresh init) — skip. The SessionStart hook still
    # enforces identity if this repo is opened in Claude.
    exit 0
    ;;
  *)
    exit 0
    ;;
esac

email="$(git config user.email 2>/dev/null || true)"

if [[ "${email}" =~ @pikolabs\.ai$ ]]; then
  exit 0
fi

if [ "${PIKO_HOOK_BYPASS:-0}" = "1" ]; then
  audit_dir="${HOME}/.piko"
  mkdir -p "${audit_dir}"
  printf '%s BYPASS-PRECOMMIT user=%s pwd=%s email=%s\n' \
    "$(date -u +%FT%TZ)" "${USER:-unknown}" "${PWD}" "${email:-<unset>}" \
    >> "${audit_dir}/hook-audit.log"
  exit 0
fi

{
  echo "error: commit blocked by PikoLabs policy"
  echo "  rule:  git user.email must end with @pikolabs.ai"
  echo "  got:   '${email:-<unset>}'"
  echo "  fix:   git config user.email <you>@pikolabs.ai"
  echo "  override: PIKO_HOOK_BYPASS=1 git commit ... (audit-logged)"
} >&2
exit 1
